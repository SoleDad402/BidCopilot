# ── LLM Settings ──────────────────────
BIDCOPILOT_LLM__MODEL=gpt-4o
BIDCOPILOT_LLM__FALLBACK_MODEL=gpt-4o-mini
OPENAI_API_KEY=your-api-key-here

# ── Browser Automation ─────────────────
BIDCOPILOT_BROWSER__HEADLESS=true

# ── Worker Pool ────────────────────────
BIDCOPILOT_WORKERS__MAX_WORKERS=5
BIDCOPILOT_WORKERS__MAX_APPLICATIONS_PER_DAY=20

# ── Matching ───────────────────────────
BIDCOPILOT_MATCHING__MIN_MATCH_SCORE=70
